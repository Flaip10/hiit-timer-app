{
    "name": "arc-timer",
    "version": "1.0.0",
    "main": "expo-router/entry",
    "scripts": {
        "start": "expo start",
        "android": "expo run:android -d",
        "android:build": "npx expo run:android -d --variant release",
        "ios": "expo run:ios -d",
        "ios:build": "npx expo run:ios -d  --configuration Release",
        "web": "expo start --web",
        "check": "npm run typecheck && npm run lint",
        "lint": "eslint . --ext .ts,.tsx",
        "typecheck": "tsc --noEmit",
        "expo:check": "expo install --check",
        "release:check": "npm run check && npm run expo:check && npx expo-doctor",
        "export:ios": "expo export --clear --platform ios --output-dir /private/tmp/arc-timer-ios-export",
        "native:generate": "npx expo prebuild --clean",
        "native:generate:ios": "npx expo prebuild --platform ios --clean",
        "native:generate:android": "npx expo prebuild --platform android --clean",
        "ios:pods": "cd ios && pod install",
        "ios:open": "open ios/*.xcworkspace",
        "android:clean": "cd android && ./gradlew clean",
        "android:release:apk": "cd android && ./gradlew assembleRelease",
        "android:install:release": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
        "android:release:aab": "cd android && ./gradlew bundleRelease",
        "prebuild:ios:clean": "expo prebuild --clean --platform ios",
        "release:ios:check": "npm run release:check && npm run export:ios",
        "assets:classic": "node scripts/generate-classic-assets.js",
        "cleaner": "node scripts/cleaner.js",
        "cleaner:hard": "node scripts/cleaner.js --hard",
        "prebuild:clean": "rm -rf android ios && expo prebuild --clean"
    },
    "dependencies": {
        "@expo-google-fonts/days-one": "^0.4.0",
        "@expo/vector-icons": "^15.0.2",
        "@react-native-async-storage/async-storage": "^2.2.0",
        "@react-navigation/drawer": "^7.5.0",
        "@react-navigation/native": "^7.1.8",
        "base-64": "^1.0.0",
        "date-fns": "^4.1.0",
        "expo": "~54.0.34",
        "expo-application": "~7.0.8",
        "expo-asset": "~12.0.12",
        "expo-audio": "~1.1.1",
        "expo-constants": "~18.0.13",
        "expo-dev-client": "~6.0.21",
        "expo-document-picker": "~14.0.7",
        "expo-file-system": "^19.0.19",
        "expo-font": "~14.0.10",
        "expo-keep-awake": "~15.0.7",
        "expo-linear-gradient": "~15.0.7",
        "expo-linking": "~8.0.12",
        "expo-localization": "~17.0.8",
        "expo-router": "~6.0.23",
        "expo-sharing": "~14.0.7",
        "expo-splash-screen": "~31.0.13",
        "expo-status-bar": "~3.0.8",
        "expo-system-ui": "~6.0.8",
        "i18next": "^25.8.7",
        "immer": "^10.2.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-i18next": "^16.5.4",
        "react-native": "0.81.5",
        "react-native-gesture-handler": "~2.28.0",
        "react-native-reanimated": "4.1.6",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-svg": "15.12.1",
        "react-native-view-shot": "4.0.3",
        "react-native-worklets": "0.5.1",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@react-native/eslint-config": "^0.82.1",
        "@types/react": "~19.1.0",
        "babel-plugin-module-resolver": "^5.0.2",
        "eslint": "^8.57.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.0",
        "typescript": "~5.9.2"
    },
    "private": true,
    "packageManager": "npm@11.6.2"
}
